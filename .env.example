PORT=3000
NODE_ENV=production

# Generate with: node -e "import('jsonwebtoken').then(({default:j})=>console.log(j.sign({},Math.random().toString(36))))"
# Or just use any long random string
JWT_SECRET=replace-with-a-long-random-secret

# MariaDB - use host gateway IP from coolify network
DB_HOST=10.0.1.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mariadb-password
DB_NAME=dashboard

# Admin login for the dashboard UI
ADMIN_USERNAME=admin
# Generate hash with: node -e "import('bcryptjs').then(b=>b.default.hash('yourpassword',10).then(console.log))"
ADMIN_PASSWORD_HASH=$2a$10$replace-with-bcrypt-hash

# JSON array of services to monitor
# Each entry: { "name": "Display Name", "url": "https://...", "domain": "domain.com.ar" }
# internalUrl: optional - if set, health checks hit this URL with Host header instead of the public URL.
# Use this to avoid hairpin NAT issues when the container is on the same machine as the services.
# Point internalUrl to the internal Traefik proxy (https://coolify-proxy or http://coolify-proxy).
MONITORED_SERVICES=[{"name":"Main Site","url":"https://armaca.com.ar","domain":"armaca.com.ar","internalUrl":"http://coolify-proxy"},{"name":"Dra. Fernandez","url":"https://drafernandezroxana.com.ar","domain":"drafernandezroxana.com.ar","internalUrl":"http://coolify-proxy"},{"name":"HTTP Requests","url":"https://httprequests.armaca.com.ar","domain":"httprequests.armaca.com.ar","internalUrl":"http://coolify-proxy"},{"name":"Sushi","url":"https://sushi.armaca.com.ar","domain":"sushi.armaca.com.ar","internalUrl":"http://coolify-proxy"},{"name":"Notes App","url":"https://notesapp.armaca.com.ar","domain":"notesapp.armaca.com.ar","internalUrl":"http://coolify-proxy"}]

# Traefik API - accessible from within the coolify Docker network
TRAEFIK_API_URL=http://coolify-proxy:8080

# Frontend URL for CORS (set to your dashboard domain in production)
FRONTEND_URL=https://dashboard.armaca.com.ar

# Metrics collection interval in seconds
COLLECT_INTERVAL_SECONDS=60

# How many days to keep historical data
RETENTION_DAYS=7
